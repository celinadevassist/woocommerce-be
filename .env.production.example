# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file and set values in your deployment platform (Coolify, Docker, etc.)
# DO NOT commit actual secrets to version control
# ===========================================

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=production
PORT=3041
APP_NAME=Idea-Keep
APP_URL=https://idea-keep.smartlabtec.com
FRONTEND_URL=https://idea-keep.smartlabtec.com
BACKEND_URL=https://api.idea-keep.2zpoint.com
MAX_REQUEST_SIZE=50mb

# ===========================================
# Database Configuration
# ===========================================
# Use a production MongoDB connection string
DB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# ===========================================
# JWT & Authentication
# ===========================================
# IMPORTANT: Generate a secure random secret for production
# Run: openssl rand -base64 64
JWT_SECRET=<generate-secure-random-string-64-chars-minimum>
JWT_EXPIRATION=14d

# ===========================================
# Email Configuration
# ===========================================
# Provider: 'smtp' or 'mailrelay'
EMAIL_PROVIDER=smtp
SUPPORT_EMAIL=support@smartlabtec.com

# SMTP Configuration (MXrouting or similar)
SMTP_HOST=taylor.mxrouting.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@smartlabtec.com
SMTP_PASSWORD=<your-smtp-password>
EMAIL_FROM=no-reply@smartlabtec.com
EMAIL_FROM_NAME=Idea-Keep

# Email redirect URLs (must match frontend routes)
EMAIL_VERIFICATION_URL=https://idea-keep.smartlabtec.com/verify-email
PASSWORD_RESET_URL=https://idea-keep.smartlabtec.com/reset-password

# Mailrelay (if using EMAIL_PROVIDER=mailrelay)
MAILRELAY_API_URL=https://idea-keep.ipzmarketing.com/api/v1/send_emails
MAILRELAY_AUTH_TOKEN=<your-mailrelay-token>

# ===========================================
# OpenAI
# ===========================================
OPENAI_API_KEY=<your-openai-api-key>

# ===========================================
# Zoom Integration
# ===========================================
ZOOM_ACCOUNT_ID=<your-zoom-account-id>
ZOOM_CLIENT_ID=<your-zoom-client-id>
ZOOM_CLIENT_SECRET=<your-zoom-client-secret>

# ===========================================
# AWS S3
# ===========================================
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_S3_BUCKET=<your-s3-bucket-name>
AWS_REGION=us-east-2
