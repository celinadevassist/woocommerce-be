# Server
NODE_ENV=development
PORT=3041
MAX_REQUEST_SIZE=50mb

# Database
DB_URI=mongodb://localhost:27017/woocommerce

# Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=14d

# Frontend
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:3041

# Email Provider (smtp or mailrelay)
EMAIL_PROVIDER=smtp

# Zoom Integration (optional)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# OpenAI (optional)
OPENAI_API_KEY=
