# ===========================================
# CartFlow Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3062
MAX_REQUEST_SIZE=50mb

# Database (REQUIRED)
DB_URI=mongodb+srv://user:password@cluster.mongodb.net/cartflow?retryWrites=true&w=majority

# Authentication (REQUIRED)
JWT_SECRET=your-jwt-secret-min-64-characters-long-change-this-in-production
JWT_EXPIRATION=14d

# CORS - comma-separated frontend URLs (REQUIRED for production)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3062

# Email (choose provider: smtp or mailrelay)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Mailrelay (alternative email provider)
# MAILRELAY_API_KEY=
# MAILRELAY_FROM=

# AWS S3 (file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# OpenAI (AI features - optional)
OPENAI_API_KEY=

# Stripe (payment processing - optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin (push notifications - optional)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Zoom Integration (optional)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
